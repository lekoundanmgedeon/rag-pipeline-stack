# ─────────────────────────────────────────────
# BASE DE DONNÉES
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://raguser:ragpassword@localhost:5432/ragdb
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=10000

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# OLLAMA (local)
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text   # Modèle dédié embeddings
OLLAMA_LLM_MODEL=qwen3:8b             # ou gemma3:9b

# Dimensions selon modèle :
# nomic-embed-text    → 768
# mxbai-embed-large   → 1024
# all-minilm          → 384
EMBEDDING_DIMENSIONS=768

# ─────────────────────────────────────────────
# UPLOAD
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv,text/html,text/plain

# ─────────────────────────────────────────────
# CHUNKING
# ─────────────────────────────────────────────
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=80
CHUNK_MIN_TOKENS=30

# ─────────────────────────────────────────────
# WORKERS
# ─────────────────────────────────────────────
WORKER_CONCURRENCY=3
EMBEDDING_BATCH_SIZE=20   # Ollama local : batches plus petits
MAX_RETRIES=3

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
LOG_LEVEL=info
